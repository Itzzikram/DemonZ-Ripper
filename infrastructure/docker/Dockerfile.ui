# ── Builder stage ──
FROM node:20-alpine AS builder

WORKDIR /app
COPY package*.json ./
COPY turbo.json ./
COPY tsconfig.json ./

# Copy workspace packages + ripper-ui app
COPY packages/ ./packages/
COPY apps/ripper-ui/ ./apps/ripper-ui/

RUN npm ci
RUN npx turbo run build --filter=ripper-ui...

# ── Production: serve with nginx ──
FROM nginx:alpine
COPY --from=builder /app/apps/ripper-ui/dist /usr/share/nginx/html
COPY infrastructure/docker/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:80/ || exit 1
